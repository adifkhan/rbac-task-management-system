generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  assignedTasks Task[]   @relation("TaskAssignment")
  auditLogs     AuditLog[]

  @@map("users")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  assignedTo  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  assignedUser User?     @relation("TaskAssignment", fields: [assignedTo], references: [id])
  auditLogs    AuditLog[]

  @@index([assignedTo])
  @@map("tasks")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())
  
  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  PENDING
  PROCESSING
  DONE
}